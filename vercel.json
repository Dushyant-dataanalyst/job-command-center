{
  "version": 2,
  "name": "nse-trading-dashboard",
  "builds": [
    { "src": "nse_live_dashboard.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/nse_live_dashboard.html" },
    { "src": "/nse_live_dashboard.html", "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0" }, "dest": "/nse_live_dashboard.html" },
    { "src": "/(.*)", "dest": "/nse_live_dashboard.html" }
  ]
}
