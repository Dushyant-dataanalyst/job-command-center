    },
    {
      "src": "/health_check.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/health_check.json"
    },
    {
      "src": "/voter_weights.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/voter_weights.json"
    },
    {
      "src": "/quality_growth_watchlist.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/quality_growth_watchlist.json"
    },
    {
      "src": "/kite_portfolio.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/kite_portfolio.json"
    },
    {
      "src": "/kite_trade_history.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/kite_trade_history.json"
    },
    {
      "src": "/recommendation_journal.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/recommendation_journal.json"
    },
    {
      "src": "/expert_gate.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/expert_gate.json"
    },
    {
      "src": "/strategy_performance.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/strategy_performance.json"
    },
    {
      "src": "/macro_risk.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/macro_risk.json"
    },
    {
      "src": "/astro_view.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/astro_view.json"
    },
    {
      "src": "/context_score.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/context_score.json"
    },
    {
      "src": "/nse_live_dashboard.html",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0" },
      "dest": "/nse_live_dashboard.html"
    },
    { "src": "/", "dest": "/nse_live_dashboard.html" },
    { "src": "/(.*)", "dest": "/nse_live_dashboard.html" }
  ]
}
