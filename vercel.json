{
  "version": 2,
  "name": "dushyant-job-command-center",
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.json", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/dushyant-command-center.html" },
    { "src": "/(.*\\.html)", "headers": { "Cache-Control": "no-store, no-cache, must-revalidate" }, "dest": "/$1" },
    { "src": "/(.*\\.json)", "headers": { "Cache-Control": "no-store, no-cache, must-revalidate" }, "dest": "/$1" }
  ]
}
