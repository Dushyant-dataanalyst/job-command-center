{
  "version": 2,
  "name": "nse-trading-dashboard",
  "builds": [
    { "src": "nse_live_dashboard.html", "use": "@vercel/static" },
    { "src": "fo_latest.json",          "use": "@vercel/static" },
    { "src": "trade_journal.json",      "use": "@vercel/static" },
    { "src": "sector_rotation.json",    "use": "@vercel/static" },
    { "src": "market_mood.json",        "use": "@vercel/static" },
    { "src": "news_feed.json",          "use": "@vercel/static" },
    { "src": "equity_journal.json",     "use": "@vercel/static" },
    { "src": "stock_fo.json",           "use": "@vercel/static" },
    { "src": "equity_scan.json",        "use": "@vercel/static" },
    { "src": "equity_scan_history.json","use": "@vercel/static" },
    { "src": "market_regime.json",      "use": "@vercel/static" },
    { "src": "health_check.json",       "use": "@vercel/static" },
    { "src": "voter_weights.json",      "use": "@vercel/static" },
    { "src": "quality_growth_watchlist.json", "use": "@vercel/static" },
    { "src": "kite_portfolio.json",     "use": "@vercel/static" },
    { "src": "kite_trade_history.json", "use": "@vercel/static" },
    { "src": "recommendation_journal.json", "use": "@vercel/static" },
    { "src": "expert_gate.json",        "use": "@vercel/static" },
    { "src": "strategy_performance.json", "use": "@vercel/static" },
    { "src": "macro_risk.json",         "use": "@vercel/static" },
    { "src": "astro_view.json",         "use": "@vercel/static" },
    { "src": "context_score.json",      "use": "@vercel/static" },
    { "src": "api/save-positions.js",   "use": "@vercel/node" }
  ],
  "routes": [
    {
      "src": "/api/save-positions",
      "dest": "/api/save-positions.js"
    },
    {
      "src": "/fo_latest.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/fo_latest.json"
    },
    {
      "src": "/trade_journal.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/trade_journal.json"
    },
    {
      "src": "/sector_rotation.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/sector_rotation.json"
    },
    {
      "src": "/market_mood.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/market_mood.json"
    },
    {
      "src": "/news_feed.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/news_feed.json"
    },
    {
      "src": "/equity_journal.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/equity_journal.json"
    },
    {
      "src": "/stock_fo.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
      "dest": "/stock_fo.json"
    },
    {
      "src": "/equity_scan.json",
      "headers": { "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0", "Access-Control-Allow-Origin": "*" },
